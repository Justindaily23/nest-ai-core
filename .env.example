# --- Application Environment ---
NODE_ENV=development
PORT=3000

# --- PostgreSQL Database Block ---
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=nest_ai_core

# Standard connection string for external tools/migrations
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nest_ai_core
DIRECT_URL=

# --- Redis Core Infrastructure ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379

# --- Provider-Agnostic AI Layer (Days 4–6 Placeholder) ---
LLM_PROVIDER=openai
OPENAI_API_KEY=your_temporary_mock_key_here
RAG_TOKEN_BUDGET=6000
LLM_MODEL=gpt-4o-mini